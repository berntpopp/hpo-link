# Docker environment for hpo-link behind Nginx Proxy Manager.
# Copy to .env.docker for the NPM compose deployment:
#
#   cp .env.docker.example .env.docker
#
# HPO_LINK_IMAGE is required; every other key is optional (the image and
# docker/docker-compose.npm.yml carry safe defaults), so this file otherwise just
# pins the external NPM network and lets you tune logging / resource limits
# without editing the compose file.
# The NPM Compose file pins the strict application Host allowlist to loopback
# plus hpo-link.genefoundry.org and sends Host: localhost for its healthcheck.

# --- Released Image (required) ---
# The NPM and prod deployments pull the released, attested image from GHCR; they
# never build. Pin a DIGEST, not a tag: there is no `latest`, and only a digest is
# immutable. Resolve it from the release asset `application-release-manifest.json`
# (.image.digest), or:
#   docker buildx imagetools inspect ghcr.io/berntpopp/hpo-link:<version>
# The placeholder below is not a real digest — replace it before deploying; it exists
# only so `compose config` can render without weakening the fail-closed guard.
HPO_LINK_IMAGE=ghcr.io/berntpopp/hpo-link@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# ---- Nginx Proxy Manager (docker/docker-compose.npm.yml) ----
# External NPM network the container joins for reverse-proxy routing.
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Logging ----
LOG_LEVEL_API=INFO

# ---- NPM resource limits (optional) ----
HPO_API_MEMORY_LIMIT=1g
HPO_API_CPU_LIMIT=1.0
